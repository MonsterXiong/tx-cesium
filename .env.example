# 应用配置
VITE_APP_TITLE=React Template
VITE_APP_BASE_API=/api
VITE_APP_PORT=3000

# Cesium 配置 - 内网部署
# 本项目已配置为内网模式，Cesium 使用本地资源
# 
# VITE_CESIUM_BASE_URL：留空使用本地资源（推荐）
# VITE_CESIUM_ACCESS_TOKEN：留空即可（内网环境通常不需要）
VITE_CESIUM_BASE_URL=
VITE_CESIUM_ACCESS_TOKEN=

# 说明：
# - 开发环境：Cesium 从 node_modules 加载
# - 生产环境：Cesium 资源打包到 dist/cesium 目录
# - 无需外网 CDN，完全离线可用
